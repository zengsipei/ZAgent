#!/bin/sh
# 通知推送（#8）：claude hooks 与 codex notify 的共用入口，推送到 ntfy 和/或 Bark。
# - claude hooks（Notification / Stop）：payload JSON 从 stdin 进
# - codex notify（agent-turn-complete）：payload JSON 作为第一个参数
# 未配置 ZAGENT_NTFY_URL / ZAGENT_BARK_URL 时静默退出；推送失败只记 stderr，不让 hook 报错。
set -u

if [ "$#" -ge 1 ]; then
  payload="$1"
else
  payload="$(cat)"
fi

event="$(printf '%s' "$payload" | jq -r '.hook_event_name // .type // empty' 2>/dev/null)" || exit 0

case "$event" in
  Notification)
    title="Claude 需要你"
    body="$(printf '%s' "$payload" | jq -r '.message // "需要权限确认或已空闲"')"
    ;;
  Stop)
    title="Claude 完成回答"
    body="任务告一段落，回来看结果"
    ;;
  agent-turn-complete)
    title="Codex 完成回答"
    body="$(printf '%s' "$payload" | jq -r '."last-assistant-message" // "任务告一段落" | .[0:200]')"
    ;;
  *)
    exit 0
    ;;
esac

# 会话可辨识（验收项）：payload 带 cwd 时把目录名拼进标题
cwd="$(printf '%s' "$payload" | jq -r '.cwd // empty')"
if [ -n "$cwd" ]; then
  title="$title · $(basename "$cwd")"
fi

# ntfy：用 JSON publish（HTTP header 不吃 UTF-8，中文标题必须走 JSON 体）。
# ZAGENT_NTFY_URL 形如 https://ntfy.sh/<topic>，末段是 topic
if [ -n "${ZAGENT_NTFY_URL:-}" ]; then
  jq -n \
    --arg topic "${ZAGENT_NTFY_URL##*/}" \
    --arg title "$title" \
    --arg body "$body" \
    --arg click "${ZAGENT_PWA_URL:-}" \
    '{topic: $topic, title: $title, message: $body}
     + (if $click != "" then {click: $click} else {} end)' \
    | curl -fsS -m 10 -X POST --data-binary @- "${ZAGENT_NTFY_URL%/*}" >/dev/null \
    || echo "zagent-notify: ntfy 推送失败" >&2
fi

# Bark：GET 路径带 title/body（@uri 编码），点开通知回 PWA 用 url 参数。
# ZAGENT_BARK_URL 形如 https://api.day.app/<device-key>
if [ -n "${ZAGENT_BARK_URL:-}" ]; then
  t="$(jq -rn --arg s "$title" '$s | @uri')"
  b="$(jq -rn --arg s "$body" '$s | .[0:200] | @uri')"
  query=""
  if [ -n "${ZAGENT_PWA_URL:-}" ]; then
    query="?url=$(jq -rn --arg s "$ZAGENT_PWA_URL" '$s | @uri')"
  fi
  curl -fsS -m 10 "${ZAGENT_BARK_URL%/}/$t/$b$query" >/dev/null \
    || echo "zagent-notify: Bark 推送失败" >&2
fi

exit 0
