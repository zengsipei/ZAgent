# Hub 应用层底线认证 token（必填，至少 32 个字符的随机串）
# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ZAGENT_TOKEN=

# 额外允许的 Origin（逗号分隔，可选；Vite 开发端 5173 已默认在白名单内）
# 远程接入 Tailscale 主路径时在这里加 tailscale serve 地址，如 https://<机器名>.<tailnet>.ts.net
# ZAGENT_ALLOWED_ORIGINS=

# docker compose 部署：同源 http://localhost:7433 已固定放行；
# 接入隧道域名时在这里追加，如 https://zagent.example.com
# （此变量仅由 docker-compose.yml 拼进 ZAGENT_ALLOWED_ORIGINS，Hub 本身不读它）
# ZAGENT_EXTRA_ORIGINS=

# Hub 监听端口（默认 7433）与监听地址（默认 127.0.0.1；容器部署由镜像设为 0.0.0.0）
# ZAGENT_PORT=7433
# ZAGENT_HOST=127.0.0.1

# 静态文件根目录（web 构建产物）：Win 直跑日用形态设为 <repo>\packages\web\dist（先 npm run build -w @zagent/web）；
# 容器部署由镜像设置；vite 开发时无需设置
# ZAGENT_STATIC_DIR=F:\zsp\Learn\ZAgent\packages\web\dist

# 会话 shell（默认 bash）
# ZAGENT_SHELL=bash

# 新建会话的 cwd 预设列表（逗号分隔，可选；默认仅用户主目录，前端仍可手输任意路径）
# ZAGENT_CWDS=F:\zsp\Learn,F:\zsp\Work

# 通知闭环（可选，二选一或都配；不配则不推送）：
# ntfy：服务地址 + topic（topic 即末段；自建服务同格式）
# ZAGENT_NTFY_URL=https://ntfy.sh/你的-topic-长随机串
# Bark（iOS）：服务地址 + device key
# ZAGENT_BARK_URL=https://api.day.app/你的DeviceKey
# 点开通知回到的 PWA 地址（可选；不配则通知不带跳转）
# ZAGENT_PWA_URL=http://localhost:7433

# 远程接入主路径为 Tailscale（见 docs/deploy.md，无需下列变量）。
# 以下仅 IPv6 直连兜底路径（ADR-0007）需要：docker compose --profile public up -d 启用 Caddy TLS 终结
# 步骤见 docs/deploy-public.md；记得把 https://域名 加进 ZAGENT_EXTRA_ORIGINS
# ZAGENT_DOMAIN=zagent.example.com
